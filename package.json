{
  "name": "orchestr-actions-sdk",
  "version": "0.1.0",
  "description": "Orchestr Action SDK — clean-room, transport-agnostic actions & triggers for the Orchestr automation platform.",
  "license": "SEE LICENSE IN LICENSE.md",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:live": "ORCHESTR_LIVE=1 NODE_OPTIONS=--experimental-vm-modules jest",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test"
  },
  "keywords": [
    "orchestr",
    "actions",
    "automation",
    "workflow",
    "integrations"
  ],
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/showdown": "^2.0.6",
    "@types/turndown": "^5.0.6",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^4.5.7",
    "jsonata": "^2.2.1",
    "node-html-parser": "^6.1.13",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "showdown": "^2.1.0",
    "turndown": "^7.2.4",
    "unpdf": "^1.6.2"
  }
}
